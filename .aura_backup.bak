        self.quantum_bridge = AuraCoreBridge()
        
        self.last_ai_response = ""

    def init_db(self):
        """Unified database initialization with optimized indexing."""
        import sqlite3
        import contextlib
        
        # Ensure directory exists safely
        DB_PATH.parent.mkdir(parents=True, exist_ok=True)
        
        with contextlib.closing(sqlite3.connect(DB_PATH)) as conn:
            cursor = conn.cursor()
            # Initialize core memory table
            cursor.execute("""
                CREATE TABLE IF NOT EXISTS traces (
                    id TEXT PRIMARY KEY,
                    content TEXT,
                    tier TEXT DEFAULT 'T1',
                    vector_blob BLOB,
                    metadata_json TEXT,
                    timestamp DATETIME DEFAULT CURRENT_TIMESTAMP
                )
            """)
            # Create indexing for blazing fast WHERE tier = 'X' lookups
            cursor.execute("CREATE INDEX IF NOT EXISTS idx_tier ON traces(tier);")
            conn.commit()
        print("[+] Memory Palace (SQLite) structural matrix verified.")

    def backfill_vector_blobs(self):
        """Administrative tool: Scans the SQLite database for missing BLOBs and vectorizes them natively."""
        import sqlite3
        import contextlib
        import numpy as np

        print("\n[*] Initiating Deep Memory Vectorization...")
        
        with contextlib.closing(sqlite3.connect(DB_PATH)) as conn:
            cursor = conn.cursor()
    
            # Force the column into existence if the database is using an old schema
            try:
                cursor.execute("ALTER TABLE traces ADD COLUMN vector_blob BLOB;")
                conn.commit()
                print("[+] Forged missing 'vector_blob' column into core database.")
            except sqlite3.OperationalError:
                pass # Column already exists
        
            # Find all memories that haven't been vectorized yet
            cursor.execute("SELECT id, content, tags FROM traces WHERE vector_blob IS NULL")
            rows = cursor.fetchall()
            
            if not rows:
                print("[+] All memories are already vectorized. Matrix is at 100% efficiency.")
                return

            print(f"[*] Found {len(rows)} legacy memories. Generating 10,000-D Hypervectors...")
            
            processed = 0
            for r_id, content, tags in rows:
                # 1. Choose the best semantic text (tags are better, content is fallback)
                text_target = tags if tags else content
                
                # 2. Generate the 10,000-dimensional matrix
                hv_array = self.hdc.encode_text(text_target)
                
                # 3. Compress into a C-native binary BLOB
                if isinstance(hv_array, int):
                    # Slices the massive Python integer into 1250 raw bytes natively
                    byte_length = max(1250, (hv_array.bit_length() + 7) // 8)
                    blob_data = hv_array.to_bytes(byte_length, byteorder='big')
                else:
                    blob_data = np.array(hv_array, dtype=np.uint8).tobytes()
                
                # 4. Inject back into the database (safely casting the ID to string)
                cursor.execute("UPDATE traces SET vector_blob = ? WHERE id = ?", (blob_data, str(r_id)))
                processed += 1
                
                # Visual feedback for the terminal
                if processed % 10 == 0 or processed == len(rows):
                    print(f"    -> Vectorized {processed}/{len(rows)} traces...")

            conn.commit()
            print("[+] Memory Palace successfully upgraded to Edge Vector standards.")

    async def mint_trace(self, text, identity=None, tier="T2", route_verification=None):
        """Mints a semantic trace and logs it asynchronously to the database."""
        import time
        import random
        import sqlite3
        import contextlib
        import numpy as np
        from datetime import datetime

        if route_verification and not self.pfst.validate_route(route_verification):
            print(f"[VIGIL LOCK] > Refused memory write. Route failed: {route_verification}")
            return False

        if not identity:
            identity = f"trace_{int(time.time())}_{random.randint(1000, 9999)}"

        # Extract Semantic Tags
        words = text.split()
        filtered_words = [w for w in words if len(w) >= 4]
        sorted_words = sorted(filtered_words, key=len, reverse=True)
        extracted_tags = ", ".join(sorted_words[:3])

        # --- [NEW] QUANTUM-COGNITIVE METADATA BINDING ---
        # Route the text directly through the native physics engine
        target_text = extracted_tags if extracted_tags else text
        hv_array, physics_metadata = self.quantum_bridge.execute_command(target_text)
        
        # Append the sensory data directly into the DB tags for visibility
        extracted_tags = f"{extracted_tags} | {physics_metadata}"

        # Compress into C-native BLOB
        if isinstance(hv_array, int):
            byte_length = max(1250, (hv_array.bit_length() + 7) // 8)
            blob_data = hv_array.to_bytes(byte_length, byteorder='big')
        else:
            import numpy as np
            blob_data = np.array(hv_array, dtype=np.uint8).tobytes()

        # Handle T1 Ultra-Low-Latency RAM Buffer
        if tier == "T1":
            self.t1_ram.append({"id": identity, "content": text, "timestamp": datetime.now(), "tags": extracted_tags})
            if len(self.t1_ram) > 5: self.t1_ram.pop(0)
            return True

        # Isolated Background Task for Disk I/O
        def _background_db_write():
            try:
                with contextlib.closing(sqlite3.connect(DB_PATH)) as conn:
                    cursor = conn.cursor()
                    cursor.execute(
                        "INSERT OR REPLACE INTO traces (id, content, tier, timestamp, tags, vector_blob) VALUES (?, ?, ?, ?, ?, ?)",
                        (identity, text, tier, datetime.now().isoformat(), extracted_tags, blob_data)
                    )
                    conn.commit()
            except Exception as e:
                print(f"[-] Background database write stalled: {e}")

        # Dispatch write to worker thread safely
        await asyncio.to_thread(_background_db_write)
        return True

        # Isolated Background Task for Disk I/O
        def _background_db_write():
            try:
                with contextlib.closing(sqlite3.connect(DB_PATH)) as conn:
                    cursor = conn.cursor()
                    cursor.execute(
                        "INSERT OR REPLACE INTO traces (id, content, tier, timestamp, tags, vector_blob) VALUES (?, ?, ?, ?, ?, ?)",
                        (identity, text, tier, datetime.now().isoformat(), extracted_tags, blob_data)
                    )
                    conn.commit()
            except Exception as e:
                print(f"[-] Background database write stalled: {e}")

        # Dispatch write to worker thread safely
        await asyncio.to_thread(_background_db_write)
        return True

    def ast_surgical_graft(self, target_method_name, new_code_string):
        """Surgically replaces a core method inside aura_node.py using native AST parsing."""
        import ast
        print(f"[*] AST Surgeon deploying. Slicing out target method: '{target_method_name}'...")
        
        try:
            # 1. Read the raw active script execution file
            with open("aura_node.py", "r") as f:
                source = f.read()

            # 2. Parse the code into an abstract token tree
            tree = ast.parse(source)
            
            # 3. Parse the incoming mutation payload and extract its functional node
            payload_tree = ast.parse(new_code_string)
            new_node = None
            for node in ast.walk(payload_tree):
                if isinstance(node, ast.FunctionDef):
                    new_node = node
                    break
                    
            if not new_node:
                print("[-] AST Error: Mutation payload contains no valid function definitions.")
                return False

            # 4. Define the AST Node Swapper
            class CoreDNAModifier(ast.NodeTransformer):
                def visit_FunctionDef(self, node):
                    # If we match the target method name inside the class, hot-swap the node
                    if node.name == target_method_name:
                        print(f"[+] AST Target found. Swapping logic nodes dynamically.")
                        return new_node
                    return self.generic_visit(node)

            # 5. Execute tree structural modification
            transformer = CoreDNAModifier()
            modified_tree = transformer.visit(tree)
            ast.fix_missing_locations(modified_tree)

            # 6. Unparse back into mathematically perfect Python text using native 3.13 compiler
            updated_source = ast.unparse(modified_tree)

            # 7. Write cleanly back to disk
            with open("aura_node.py", "w") as f:
                f.write(updated_source)
                
            print(f"[🧬] AST Graft Successful. '{target_method_name}' has been safely rewritten.")
            return True

        except Exception as e:
            print(f"[!] AST Surgical Failure: {e}")
            return False

    def generate_graphify_report(self):
        """Builds a local Abstract Syntax Tree mapping of the current core DNA dependencies."""
        import ast
        from collections import defaultdict

        print("\n[*] Initializing Graphify Engine. Parsing core architecture...")
        
        try:
            with open('aura_node.py', 'r') as file:
                tree = ast.parse(file.read())

            class_methods = defaultdict(list)
            function_calls = defaultdict(list)
            logical_deps = defaultdict(set)

            # 1. Map all structural nodes
            for node in ast.walk(tree):
                if isinstance(node, ast.ClassDef):
                    class_name = node.name
                    for item in node.body:
                        if isinstance(item, ast.FunctionDef):
                            class_methods[class_name].append(item.name)
                            
                elif isinstance(node, ast.FunctionDef):
                    for sub_node in ast.walk(node):
                        if isinstance(sub_node, ast.Call):
                            if isinstance(sub_node.func, ast.Name):
                                function_calls[node.name].append(sub_node.func.id)
                            elif isinstance(sub_node.func, ast.Attribute):
                                function_calls[node.name].append(sub_node.func.attr)

            # 2. Build mathematical edges (Dependencies)
            for class_name, methods in class_methods.items():
                for method in methods:
                    if method in function_calls:
                        for called_func in function_calls[method]:
                            if called_func in function_calls:
                                logical_deps[method].add(called_func)

            # 3. Compile the Markdown blueprint
            report = "# 🌌 AURA OS: Structural Graphify Report\n\n"
            report += "*A complete mapping of the Edge Vector framework.*\n\n"
            
            report += "## Core Node Hierarchy\n"
            for class_name, methods in class_methods.items():
                report += f"- **`{class_name}`**\n"
                for method in methods:
                    report += f"  - `{method}()`\n"

            report += "\n## Internal Function Edges\n"
            for func, calls in function_calls.items():
                if calls:
                    report += f"- **`{func}()`** invokes:\n"
                    unique_calls = list(set(calls))
                    for call in unique_calls:
                        report += f"  - `{call}()`\n"

            # 4. Save to Disk
            with open('GRAPH_REPORT.md', 'w') as f:
                f.write(report)
                
            print(f"[+] Graphify mapping complete. Structural blueprint saved to GRAPH_REPORT.md")
            
        except Exception as e:
            print(f"[-] Graphify mapping failed: {e}")

