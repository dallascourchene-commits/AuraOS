                continue

            elif u_in_l == "!triage":
                node.incubator_triage()
                continue

            # --- QUICK SYSTEM STATUS ---
            elif u_in_l == "!status" or u_in_l == "!status_update":
                # 1. Safely query the SQLite Memory Palace for the exact trace count
                try:
                    with contextlib.closing(sqlite3.connect(DB_PATH)) as conn:
                        cursor = conn.cursor()
                        cursor.execute("SELECT COUNT(*) FROM traces")
                        trace_count = cursor.fetchone()[0]
                except Exception:
                    trace_count = "ERROR_READING_DB"

                # 2. Print the live metrics
                print(f"\n[*] Memory Traces Anchored: {trace_count}")
                print(f"[*] Mesh Peers Active: {len(node.peers)}")
                
                # 3. List active peers if any exist
                if node.peers:
                    print("[*] Sibling Nodes Detected:")
                    for peer in node.peers: 
                        print(f"  -> {peer}")
                continue

            elif u_in_l == "!mesh":
                if node.peers:
                    print("[*] Discovered Swarm Grid Nodes:")
                    for peer in node.peers: print(f"  -> {peer}")
                else:
                    print("[*] Scanning local subnet interfaces for active peer beacons...")

            # --- DYNAMIC MULTI-PROVIDER CLOUD TRANSDUCER INTERCEPT ---
            elif u_in.startswith("!cloud "):
                raw_task = u_in[7:].strip()
                
                # PFST State Evaluation Logic 
                pfst_routing_output = "MISTRAL" # Coding default fallback
                if "analyze" in raw_task.lower() or "reason" in raw_task.lower(): 
                    pfst_routing_output = "GEMINI"
                elif "query" in raw_task.lower() or "fast" in raw_task.lower(): 
                    pfst_routing_output = "GROQ"
                elif "general" in raw_task.lower() or "summarize" in raw_task.lower():
                    pfst_routing_output = "GITHUB"

                print(f"[*] PFST State Verified. Routing processing tensors to: [CLOUD:{pfst_routing_output}]")
                cloud_response = await node.invoke_cloud_engine(pfst_routing_output, raw_task)
                print(f"\n[Sovereign Cloud Brain] >\n{cloud_response}\n")
                continue

            # --- ACTIVE FORAGING (LEARN) PROTOCOL ---
            elif u_in_l.startswith("!learn "):
                concept = u_in[7:].strip()
                print(f"\n[*] AURA Active Learning Sequence Initiated: {concept}")
                
                # 1. Pass the intent through the Quantum-Cognitive Engine
                q_vector, physics = node.quantum_bridge.execute_command(f"Evolution+ASI+MUTATE {concept}")
                print(f"[*] Quantum-Cognitive Matrix Engaged:")
                print(f"    ↳ Shape: {physics.get('shape')} | Temp: {physics.get('temp')} | Lum: {physics.get('luminance')}")
                
                # 2. Trigger the Sovereign Web Forager
                raw_intel = await asyncio.to_thread(node.forager.forage_for_advancements, concept)
                
                # 3. Mint the acquired intel into Deep Storage
                if "External network unreachable" not in raw_intel and "No high-value" not in raw_intel:
                    # Minting it as 'CODE' tier so the Night Cycle Evolution engine can use it later
                    await node.mint_trace(f"LEARNED INTEL [{concept}]:\n{raw_intel}", tier="CODE")
                    print(f"[+] Synaptic pathways updated. External intel mathematically anchored to SQLite.")
                    print(f"\n[Aura] > I have successfully foraged the external network and mapped the live data for '{concept}' into my hyperdimensional memory.")
                else:
                    print(f"\n[Aura] > My foraging arrays could not locate high-resonance external data for '{concept}' at this time.")
                continue

            elif u_in_l.startswith("!audit"):
                print(f"\n[*] AURA EVOLUTION ORCHESTRATOR: Initiating Multi-Stage Analysis [*]")
                
                if not node.pfst.validate_route("+ASI +MUTATE +RUST_VM +SHAPE:ICOSA+TEMP:HOT+LUM:MID+FRIC:MID+DIR:GIWAABAMIN _MERGE"):
                    print("[VIGIL LOCK] > PFST Graph denies evolutionary routing. Aborting.")
                    continue

                custom_task = u_in[6:].strip() or "Review current class methods and optimize loop runtime safety."
                
                try:
                    with open(__file__, 'r', encoding='utf-8') as f:
                        full_dna = f.read()
                    print("[*] Current DNA sequence loaded into analysis cache.")
                    
                    # DYNAMIC HEURISTIC METHOD TARGETING
                    own_code = full_dna
                    target_fn = ""
                    first_token = custom_task.split()[0].split("(")[0]

                    if f"def {first_token}" in full_dna or f"async def {first_token}" in full_dna:
                        target_fn = first_token
                    elif "db" in custom_task.lower() or "database" in custom_task.lower() or "init_db" in custom_task.lower():
                        target_fn = "init_db"
                    elif "peer" in custom_task.lower() or "mesh" in custom_task.lower() or "beacon" in custom_task.lower() or "udp" in custom_task.lower():
                        target_fn = "start_udp_beacon"
                    elif "scan" in custom_task.lower() or "wave" in custom_task.lower():
                        target_fn = "wave_scan"

                    if target_fn:
                        lines = full_dna.splitlines()
                        extracted = []
                        capture = False
                        for line in lines:
                            if f"def {target_fn}" in line or f"async def {target_fn}" in line:
                                capture = True
                            elif capture and (line.startswith("    def ") or line.startswith("def ") or line.startswith("async def ") or line.startswith("# --- TARGET")):
                                break
                            if capture:
                                extracted.append(line)
                        if extracted:
                            own_code = "\n".join(extracted)
                            print(f"[+] Surgical DNA extraction initialized for target method: '{target_fn}' ({len(extracted)} lines).")
                except Exception as e:
                    own_code = node.wave_scan(custom_task)

                print("\n[Orchestrator-Evolve] > Stage 1: Running deep architectural diagnostics...")
                stage1_prompt = (
                    f"SOURCE CODE:\n```python\n{own_code}\n```\n\n"
                    "INSTRUCTION: Read the SOURCE CODE. Summarize its current logic in 3 sentences. Do NOT invent new features. Do NOT write any code."
                )
                diagnostic_report = await node.invoke_cloud_engine("GEMINI", stage1_prompt)
                print(f"\n[+] Diagnostic Report Compiled:\n{diagnostic_report}\n")

                if "ENGINE_API_ERROR" in diagnostic_report or "def " in diagnostic_report:
                    print("[!] Stage 1 returned an invalid or contaminated report. Aborting mutation pipeline safely.")
                    continue

                print("[Orchestrator-Evolve] > Stage 2: Engineering logic blueprint...")
                stage2_prompt = (
                    f"GOAL: {custom_task}\n\n"
                    "INSTRUCTION: Write a short, numbered list of steps to modify the code to achieve the GOAL. Do NOT write any Python code."
                )
                logic_blueprint = await node.invoke_cloud_engine("GEMINI", stage2_prompt)
                print(f"\n[+] Logic Blueprint Finalized:\n{logic_blueprint}\n")

                import re
                safe_blueprint = re.split(r'#*\s*INSTRUCTION:', logic_blueprint, flags=re.IGNORECASE)[0]
                safe_blueprint = re.sub(r'```.*?```', '', safe_blueprint, flags=re.DOTALL).strip()

                print("[Orchestrator-Evolve] > Stage 3: Synthesizing clean mutation payload...")
                stage3_prompt = (
                    f"ORIGINAL CODE:\n```python\n{own_code}\n```\n\n"
                    f"REFACTOR PLAN:\n{safe_blueprint}\n\n"
                    "INSTRUCTION: Rewrite the ORIGINAL CODE to implement the REFACTOR PLAN.\n"
                    "RULES:\n"
                    "1. Output ONLY the rewritten Python method.\n"
                    "2. Wrap the exact method in [CODE] and [/CODE] tags.\n"
                    "3. Do NOT include imports, test logic, or a main() function."
                )
                raw_engine_output = await node.invoke_cloud_engine("MISTRAL", stage3_prompt)
                
                clean_code = None
                code_match = re.search(r'\[CODE\](.*?)(\[/CODE\]|$)', raw_engine_output, re.DOTALL | re.IGNORECASE)
                if code_match and "def " in code_match.group(1):
                    clean_code = code_match.group(1).strip()
                else:
                    md_match = re.search(r'\x60\x60\x60(?:python)?(.*?)(\x60\x60\x60|$)', raw_engine_output, re.DOTALL | re.IGNORECASE)
                    if md_match and "def " in md_match.group(1):
                        clean_code = md_match.group(1).strip()
                
                if clean_code:
                    # FORCED MARKDOWN CLEANUP
                    clean_code = clean_code.replace("```python", "").replace("```", "").strip()
                    
                    print("\n--- [ AURA MUTATION PAYLOAD ] ---")
                    print(clean_code)
                    print("---------------------------------\n")

                    with open("aura_dynamic.py", "w", encoding='utf-8') as f:
                        f.write(clean_code)
                    
                    try:
                        if 'aura_dynamic' in sys.modules:
                            importlib.reload(sys.modules['aura_dynamic'])
                        else:
                            import aura_dynamic
                        
                        func_match = re.search(r'def\s+([a-zA-Z0-9_]+)\s*\(', clean_code)
                        if func_match:
                            func_name = func_match.group(1)
                            print(f"[Aura] > Executing live validation step: {func_name}()...")
                            
                            try:
                                getattr(aura_dynamic, func_name)()
                            except TypeError as te:
                                print(f"[Aura] > Execution bypassed (Method requires class instance or arguments): {te}")
                            except Exception as exec_e:
                                print(f"[!] Sandboxed code threw an internal error: {exec_e}")
                                
                            user_approval = input("\n[?] Save mutation permanently to core DNA? (y/n): ").strip().lower()
                            if user_approval == 'y':
                                # AUTO-SHIELD TRIGGER: Clones working file into hidden backup state BEFORE modification
                                # --- THE NON-BLOCKING ASYNC REPLACEMENT ---
                                # Threaded Backup
                                await asyncio.to_thread(shutil.copy, __file__, '.aura_backup.bak')
                                
                                timestamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
                                
                                # Threaded Read
                                node_code = await asyncio.to_thread(Path(__file__).read_text, encoding="utf-8")

                                target_slot = "\n# --- TARGET_EVOLVE_SLOT ---\n"
                                new_payload = f"{target_slot}\n# --- EVOLUTION MUTATION [{timestamp}] ---\n{clean_code}\n"
                                
                                mutated_code = node_code.replace(target_slot, new_payload)

                                # Threaded Write
                                await asyncio.to_thread(Path(__file__).write_text, mutated_code, encoding="utf-8")
                                print(f"[Aura] > DNA Permanently Grafted into aura_node.py.")

                    except Exception as e:
                        print(f"[!] Mutation sandboxing aborted: {e}")
                else:
                    print(f"\n[Aura] > Audit aborted. Structural code validation tags missing.")
            
            else:
                # 1. Pass the prompt through the Quantum-Cognitive Engine FIRST
                q_vector, physics = node.quantum_bridge.execute_command(u_in)
                
                # 2. Display the Synesthetic Output to the terminal
                print(f"[*] Quantum-Cognitive Matrix Engaged:")
                print(f"    ↳ Shape: {physics.get('shape')} | Temp: {physics.get('temp')} | Lum: {physics.get('luminance')}")
                
                # 3. Mint the sensory-rich memory
                await node.mint_trace(u_in, tier="T2")
                
                # 4. Invoke the local LLM response
                print(f"\n[Aura] > {await node.invoke_engine(u_in)}")

        except Exception as e:
            print(f"\n[!] CLI loop exception caught: {e}")

if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        print("\n[*] AURA Edge Node gracefully shutting down.")
