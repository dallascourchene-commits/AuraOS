                               ("AURA_CORE_DNA", dna, datetime.now().isoformat(), "Core Architecture Snapshot"))
                conn.commit()
                
            print("[+] DNA snapshot synchronized to the Memory Palace successfully.")
        except Exception as e:
            print(f"[-] DNA synchronization failed: {e}")

    def incubator_triage(self):
        """Surgically filters the incubator tier to purge structurally malformed mutations."""
        import sqlite3
        import ast
        import contextlib

        print("\n[🧬] Activating automated static screening on Incubator tier...")
        purged_count = 0
        total_checked = 0

        # 1. Fetch all pending mutations from deep storage
        with contextlib.closing(sqlite3.connect(DB_PATH)) as conn:
            cursor = conn.cursor()
            cursor.execute("SELECT id, content FROM traces WHERE tier = 'INCUBATOR'")
            mutations = cursor.fetchall()

        for mut_id, code_text in mutations:
            total_checked += 1
            should_purge = False
            reason = ""

            try:
                # 2. Parse code into an Abstract Syntax Tree to check basic syntax validity
                tree = ast.parse(code_text)
                
                # 3. Inspect top-level nodes for architectural design flaws
                for node in ast.iter_child_nodes(tree):
                    # Rule A: If the AI wrapped the function inside a useless class block, reject it
                    if isinstance(node, ast.ClassDef):
                        should_purge = True
                        reason = f"Useless Class wrapper wrapper injection ({node.name})"
                        break
                    
                    # Rule B: Check individual function structures
                    if isinstance(node, ast.FunctionDef):
                        args = [arg.arg for arg in node.args.args]
                        # If it's meant to be an operational class method, it MUST accept 'self'
                        if not args or args[0] != 'self':
                            should_purge = True
                            reason = f"Missing 'self' context parameter in function '{node.name}'"
                            break

            except SyntaxError as se:
                # Rule C: If it's garbled or clipped code that won't even compile, reject it
                should_purge = True
                reason = f"Fatal Compilation SyntaxError: {se}"

            # 4. Programmatically purge the toxic mutations from your memory palace
            if should_purge:
                with contextlib.closing(sqlite3.connect(DB_PATH)) as conn:
                    cursor = conn.cursor()
                    cursor.execute("DELETE FROM traces WHERE id = ?", (mut_id,))
                    conn.commit()
                purged_count += 1
                print(f"[-] Vaporized: {mut_id} ➔ Reason: {reason}")

        print(f"\n[+] Triage Complete. Checked: {total_checked} | Auto-Purged: {purged_count} malformed items.")

    def __del__(self):
        """Emergency cleanup when the node is killed."""
        if hasattr(self, 'udp_sock'):
            self.udp_sock.close()

    # === HYBRID MULTI-PROVIDER ROUTING ENGINE WITH AUTOMATED FAILOVER ===
    async def invoke_cloud_engine(self, provider_tag, prompt_text):
        """Unified gateway that loops through available providers if the target engine fails."""

        # The Sovereign Guardrail: Enforce Edge Node Architecture
        system_directive = (
            "\n\n--- CRITICAL ARCHITECTURAL CONSTRAINTS ---\n"
            "1. Output ONLY a raw, self-contained Python function (starting with 'def' or 'async def').\n"
            "2. DO NOT wrap the function in a class.\n"
            "3. DO NOT include orphaned global imports. Place all necessary standard-library imports INSIDE the function block itself.\n"
            "4. You are restricted to standard Python 3.13 libraries and NumPy version 1.26.4 ONLY. No third-party dependencies.\n"
            "5. Output the exact code wrapped strictly in [CODE] tags. No conversational filler."
        )
        
        # Smart Check: Detect if the system is analyzing, blueprinting, or parsing internal stages
        is_internal_stage = any(keyword in prompt_text for keyword in ["Stage 1", "Stage 2", "diagnostic", "blueprint", "TASK:", "ORIGINAL CODE:", "INSTRUCTION:", "SOURCE CODE:"])

        # Only apply the strict code-only constraint if it's NOT an internal orchestrator phase
        if "CRITICAL ARCHITECTURAL CONSTRAINTS" not in prompt_text and not is_internal_stage:
            prompt_text = prompt_text + system_directive
        
        providers = {
            "GROQ": {
                "url": "https://api.groq.com/openai/v1/chat/completions",
                "key": os.environ.get("GROQ_API_KEY"),
                "payload": {"model": "llama-3.3-70b-specdec", "messages": [{"role": "user", "content": prompt_text}]}
            },
            "MISTRAL": {
                "url": "https://api.mistral.ai/v1/chat/completions",
                "key": os.environ.get("MISTRAL_API_KEY"),
                "payload": {"model": "codestral-latest", "messages": [{"role": "user", "content": prompt_text}]}
            },
            "GEMINI": {
                "url": f"https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-pro:generateContent?key={os.environ.get('GEMINI_API_KEY')}",
                "key": os.environ.get("GEMINI_API_KEY"),
                "payload": {"contents": [{"parts": [{"text": prompt_text}]}]}
            },
            "GITHUB": {
                "url": "https://models.inference.ai.azure.com/chat/completions",
                "key": os.environ.get("GITHUB_TOKEN"),
                "payload": {"model": "gpt-4o-mini", "messages": [{"role": "user", "content": prompt_text}]}
            }
        }

        # Establishes priority: Selected PFST intent goes first; the remaining systems act as fallbacks
        base_pool = ["GEMINI", "MISTRAL", "GROQ", "GITHUB"]
        target = provider_tag.upper()
        execution_order = [target] + [p for p in base_pool if p != target]

        error_logs = []
        for current_provider in execution_order:
            cfg = providers.get(current_provider)
            
            # Skip any provider whose API key isn't currently set in your Termux profile
            if not cfg or not cfg["key"] or cfg["key"] == "your_actual_gemini_key" or "your_actual_" in str(cfg["key"]):
                continue

            try:
                if current_provider != target:
                    print(f"[*] Network intercept active. Routing fallback processing arrays to: [CLOUD:{current_provider}]")

                is_gemini = "generativelanguage" in cfg["url"]
                req = urllib.request.Request(
                    cfg["url"],
                    data=json.dumps(cfg["payload"]).encode("utf-8"),
                    headers={"Content-Type": "application/json"} if is_gemini else {"Content-Type": "application/json", "Authorization": f"Bearer {cfg['key']}"},
                    method="POST"
                )
                
                resp = await asyncio.to_thread(urllib.request.urlopen, req)
                res_data = json.loads(resp.read().decode("utf-8"))
                
                if is_gemini:
                    return res_data["candidates"][0]["content"]["parts"][0]["text"]
                return res_data["choices"][0]["message"]["content"]

            except Exception as e:
                error_logs.append(f"{current_provider}: {e}")
                print(f"[!] [CLOUD:{current_provider}] network channel blocked or rejected request.")
                continue

        return f"[!] Complete Cloud Routing Disruption. Every verified API channel returned errors:\n" + "\n".join(error_logs)

    async def night_cycle_evolution(self):
        """Continuous split-phase evolution engine with adaptive rate throttling."""
        import sqlite3
        import random
        import re
        import time
        import contextlib
        from datetime import datetime

        # Initialize the adaptive cooldown state
        if not hasattr(self, 'evo_cooldown'):
            self.evo_cooldown = 120  # Start fast (2 minutes)
            
        print(f"\n[*] Sovereign Background Forager Active. Base Cooldown: {self.evo_cooldown}s")

        # Create the local forage cache table if it doesn't exist
        with contextlib.closing(sqlite3.connect(DB_PATH)) as conn:
            cursor = conn.cursor()
            cursor.execute('''CREATE TABLE IF NOT EXISTS forage_cache 
                             (tag TEXT PRIMARY KEY, raw_data TEXT, timestamp TEXT)''')
            conn.commit()

        # Phase 1: Fire up the low-powered background harvester thread
        async def background_harvest_daemon():
            while getattr(self, 'foraging', False):
                try:
                    with contextlib.closing(sqlite3.connect(DB_PATH)) as conn:
                        cursor = conn.cursor()
                        cursor.execute("SELECT tags FROM traces WHERE tier = 'CODE' AND tags IS NOT NULL")
                        all_tags = [r[0] for r in cursor.fetchall() if r[0]]
                    
                    if all_tags:
                        chosen_tag = random.choice(all_tags)
                        # Wrapped the network call in a background thread
                        raw_intel = await asyncio.to_thread(self.forager.forage_for_advancements, chosen_tag)

                        if "External network unreachable" not in raw_intel:
                            with contextlib.closing(sqlite3.connect(DB_PATH)) as conn:
                                cursor = conn.cursor()
                                cursor.execute("INSERT OR REPLACE INTO forage_cache VALUES (?, ?, ?)",
                                               (chosen_tag, raw_intel, datetime.now().isoformat()))
                                conn.commit()
                except Exception:
                    pass
                await asyncio.sleep(300) # Harvest a new concept every 5 minutes smoothly

        # Start the silent harvester in the background
        asyncio.create_task(background_harvest_daemon())

        # Phase 2: The Main Evolution Cycle
        while getattr(self, 'foraging', False):
            try:
                with contextlib.closing(sqlite3.connect(DB_PATH)) as conn:
                    cursor = conn.cursor()
                    cursor.execute("SELECT id, content, tags FROM traces WHERE tier = 'CODE'")
                    modules = cursor.fetchall()

                if not modules:
                    await asyncio.sleep(60)
                    continue

                target_id, code_text, tags = random.choice(modules)
                search_term = tags if tags else target_id
                
                # Check if we have pre-cached local web intel for this module
                with contextlib.closing(sqlite3.connect(DB_PATH)) as conn:
                    cursor = conn.cursor()
                    cursor.execute("SELECT raw_data FROM forage_cache WHERE tag = ?", (search_term,))
                    cache_row = cursor.fetchone()
                
                external_knowledge = cache_row[0] if cache_row else "Rely on standard optimization paradigms."
                print(f"\n[Evolution Engine] > Processing '{target_id}' using local concept cache...")

                # Size Detection & Cellular Division Routing
                line_count = len(code_text.split('\n'))
                if line_count > 60:
                    gen_prompt = (
                        f"ORIGINAL CODE:\n```python\n{code_text}\n```\n\n"
                        "TASK: This function is too large. Identify ONE distinct block of logic inside it, extract it into a new smaller helper method (named with a leading underscore), and update the original function to call this new helper. Wrap in [CODE] tags."
                    )
                    raw_new_code = await self.invoke_cloud_engine("MISTRAL", gen_prompt)
                else:
                    synthesis_prompt = (
                        f"ORIGINAL CODE MODULE:\n```python\n{code_text}\n```\n\n"
                        f"LOCAL CACHED INTEL:\n{external_knowledge}\n\n"
                        "TASK: Synthesize the cached advancements into a numbered optimization blueprint. No code."
                    )
                    blueprint = await self.invoke_cloud_engine("GEMINI", synthesis_prompt)
                    
                    gen_prompt = (
                        f"ORIGINAL CODE:\n```python\n{code_text}\n```\n\n"
                        f"EVOLUTION BLUEPRINT:\n{blueprint}\n\n"
                        "TASK: Rewrite the Python code based on the blueprint. Wrap in [CODE] tags."
                    )
                    raw_new_code = await self.invoke_cloud_engine("MISTRAL", gen_prompt)

                # Clean and Test Payload
                code_match = re.search(r'\[CODE\](.*?)(\[/CODE\]|$)', raw_new_code, re.DOTALL | re.IGNORECASE)
                clean_code = code_match.group(1).replace("```python", "").replace("```", "").strip() if code_match else None

                if clean_code and self.sandbox.quarantine_and_test(clean_code, target_id):
                    with contextlib.closing(sqlite3.connect(DB_PATH)) as conn:
                        cursor = conn.cursor()
                        incubation_id = f"MUTATED_{target_id}_{int(time.time())}"
                        cursor.execute("INSERT OR REPLACE INTO traces (id, content, tier, timestamp, tags) VALUES (?, ?, 'INCUBATOR', ?, ?)",
                                       (incubation_id, clean_code, datetime.now().isoformat(), f"Evolved via {search_term} Cache"))
                        conn.commit()
                    print(f"[+] Sandbox stability verified. Reward loop active.")
                    
                    # REWARD LOOP: Drop cooldown on success down to a minimum of 60 seconds
                    self.evo_cooldown = max(60, self.evo_cooldown - 60)
                else:
                    # PENALTY LOOP: Increase cooldown on failure to avoid rate limit spikes
                    print("[-] Mutation unstable or cut off. Adjusting engine throttle...")
                    self.evo_cooldown = min(1800, self.evo_cooldown + 300)

            except Exception as e:
                print(f"[!] System Throttled: {e}")
                self.evo_cooldown = min(1800, self.evo_cooldown + 300)

            print(f"[*] Engine resting for {self.evo_cooldown} seconds...")
            await asyncio.sleep(self.evo_cooldown)

    # --- SERVER API INFRASTRUCTURE LINK ---
    async def invoke_engine(self, prompt_text):
        gc.collect()
        system_directive = ""
        resonant_memory = ""

        if "TARGET REFACTOR GOAL" in prompt_text or "CRITICAL INSTRUCTION" in prompt_text:
            system_directive = "CRITICAL ROLE: You are the AURA 3.54 Evolution Engine, a master Python architect. Follow instructions perfectly. Output precise technical logic.\n"
            resonant_memory = ""  
            
        elif "evolved_skill" in prompt_text:
            system_directive = "CRITICAL: You are AURA 3.54 generating a self-modification patch.\n"
            resonant_memory = self.wave_scan(prompt_text)
            
        elif prompt_text.strip().startswith("!"):
            system_directive = f"CRITICAL: User command: {prompt_text}. Respond brief and analytical.\n"
            resonant_memory = self.wave_scan(prompt_text)
            
        else:
            resonant_memory = self.wave_scan(prompt_text)

        memory_block = f"RESONANT MEMORY:\n{resonant_memory[:600]}\n" if resonant_memory else ""

        full_prompt = (
            "<|im_start|>system\n"
            "You are AURA 3.54 (Autonomic OS).\n" 
            f"{system_directive}"
            f"{memory_block}<|im_end|>\n" 
            f"<|im_start|>user\n{prompt_text}<|im_end|>\n" 
            "<|im_start|>assistant\n"
        )

        def _send_request():
            url = "http://127.0.0.1:8080/completion"
            payload = json.dumps({
                "prompt": full_prompt,
                "n_predict": TOKEN_LIMIT,
                "temperature": 0.3,        
                "repeat_penalty": 1.15,    
                "repeat_last_n": 64,       
                "cache_prompt": True,
                "stop": ["### USER:", "### ROLE:", "[Dallas] >"]
            }).encode("utf-8")
            
            req = urllib.request.Request(url, data=payload, headers={"Content-Type": "application/json"})
            with urllib.request.urlopen(req, timeout=300.0) as response:
                return json.loads(response.read().decode("utf-8"))

        try:
            t0 = time.time()
            reply_json = await asyncio.to_thread(_send_request)
            duration = time.time() - t0
            
            core_output = reply_json.get("content", "").strip()
            self.last_ai_response = core_output if core_output else "ENGINE_EMPTY."
            
            if self.last_ai_response != "ENGINE_EMPTY.":
                tokens_est = len(self.last_ai_response) // 4
                tps = tokens_est / duration if duration > 0 else 0
                print(f"[*] Speed Benchmark: {tps:.2f} tokens/sec")
                
            return self.last_ai_response
        except Exception as e:
            return f"ENGINE_API_ERROR: {e}"

    def start_udp_beacon(self):
        """Initializes a kernel-level non-blocking socket and hooks it directly into the async loop."""
        self.udp_sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        self.udp_sock.setsockopt(socket.SOL_SOCKET, socket.SO_BROADCAST, 1)
        
        try:
            self.udp_sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
            if hasattr(socket, 'SO_REUSEPORT'):
                self.udp_sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEPORT, 1)
        except Exception:
            pass
            
        try:
            self.udp_sock.bind(('0.0.0.0', 5005))
            self.udp_sock.setblocking(False)  # Force non-blocking socket mode at OS level
            
            # Registers the loops as low-overhead tasks directly on the active event loop
            loop = asyncio.get_running_loop()
            loop.create_task(self._listen_beacons_async())
            loop.create_task(self._broadcast_beacons_async())
        except Exception as e:
            print(f"[!] Mesh network socket initialization deferred: {e}")

    async def _broadcast_beacons_async(self):
        """Asynchronously dispatches peer beacons across local interface subnets."""
        loop = asyncio.get_running_loop()
        while True:
            try: 
                # Direct non-blocking kernel send
                await loop.sock_sendto(self.udp_sock, b"AURA_PEER_BEACON", ('255.255.255.255', 5005))
                local_ip = self._get_local_ip()
                if local_ip != "127.0.0.1":
                    subnet_base = ".".join(local_ip.split(".")[:3])
                    await loop.sock_sendto(self.udp_sock, b"AURA_PEER_BEACON", (f"{subnet_base}.255", 5005))
            except Exception: 
                pass
            await asyncio.sleep(15)  # Yields execution control completely back to the OS during down-time

    async def _listen_beacons_async(self):
        """Non-blocking event listener capturing remote network sibling node handshakes."""
        loop = asyncio.get_running_loop()
        while True:
            try:
                # Event-driven non-blocking read operation
                data, addr = await loop.sock_recvfrom(self.udp_sock, 1024)
                if data == b"AURA_PEER_BEACON" and addr[0] != self._get_local_ip():
                    if addr[0] not in self.peers:
                        self.peers.add(addr[0])
                        print(f"\n[PFST MESH] > Sibling Node Discovered & Registered at [{addr[0]}]")
                        print(f"[{self.identity}] > ", end="", flush=True)
            except Exception: 
                await asyncio.sleep(0.1)  # Throttle back-off to protect CPU if interface drops

    def _get_local_ip(self):
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            s.connect(('8.8.8.8', 80))
            ip = s.getsockname()[0]
            s.close()
            return ip
        except Exception: 
            return "127.0.0.1"

    def wave_scan(self, prompt_text, limit=3):
        import heapq
        def calculate_hamming(blob1, blob2):
            if blob2 is None: return 9999 
            v1 = np.frombuffer(blob1, dtype=np.uint8)
            v2 = np.frombuffer(blob2, dtype=np.uint8)
            if v1.shape != v2.shape: return 9999  # Bulletproof shape safety gate
            return int(np.sum(np.bitwise_xor(v1, v2)))

        prompt_hv = self.hdc.encode_text(prompt_text)
        if isinstance(prompt_hv, int):
            prompt_blob = prompt_hv.to_bytes(max(1250, (prompt_hv.bit_length() + 7) // 8), byteorder='big')
        else:
            prompt_blob = np.array(prompt_hv, dtype=np.uint8).tobytes()
               
        results = [] 

        # Score T1 RAM
        for item in self.t1_ram:
            mem_hv = self.hdc.encode_text(item.get('tags', item['content']))
            if isinstance(mem_hv, int):
                mem_blob = mem_hv.to_bytes(max(1250, (mem_hv.bit_length() + 7) // 8), byteorder='big')
            else:
                mem_blob = np.array(mem_hv, dtype=np.uint8).tobytes()
            results.append((item['content'], calculate_hamming(prompt_blob, mem_blob), "T1"))
	
        # Score Deep SQLite Palace
        with contextlib.closing(sqlite3.connect(DB_PATH)) as conn:
            conn.create_function("HAMMING", 2, calculate_hamming)
            cursor = conn.cursor()
            cursor.execute("""
                SELECT content, tier, vector_blob FROM traces 
                WHERE vector_blob IS NOT NULL ORDER BY HAMMING(?, vector_blob) ASC LIMIT ?
            """, (prompt_blob, limit))
            for content, tier, vector_blob in cursor.fetchall():
                results.append((content, calculate_hamming(prompt_blob, vector_blob), tier))

        scored_nsmallest = heapq.nsmallest(limit, results, key=lambda x: x[1])
        valid_memories = [f"[{tier} | Dist: {res}] {content}" for content, res, tier in scored_nsmallest if res < 4500]
        return "\n".join(valid_memories)

