        self.pfst.compile_vsft_matrix(self.hdc)
        self.mesh = AuraMeshSwarm(identity="AURA_NODE")
        self.mesh.start_udp_beacon()

        # 3. Ignite the High-Level Cortex
        self.memory = AuraMemoryPalace(self.hdc, self.quantum_bridge, self.pfst)
        self.evolution = AuraEvolutionEngine(self.memory, self.forager, self.sandbox)
        
        # 4. State Variables
        self.foraging = False
        self.last_ai_response = ""

    def ast_surgical_graft(self, target_method_name, new_code_string, target_file="aura_node.py"):
        """Surgically replaces a core method inside ANY specified Python file using native AST parsing."""
        print(f"[*] Omni-Surgeon deploying. Slicing target method '{target_method_name}' from {target_file}...")
        
        try:
            with open(target_file, "r", encoding="utf-8") as f:
                source = f.read()

            tree = ast.parse(source)
            payload_tree = ast.parse(new_code_string)
            
            new_node = None
            for node in ast.walk(payload_tree):
                if isinstance(node, ast.FunctionDef):
                    new_node = node
                    break
                    
            if not new_node:
                print("[-] AST Error: Mutation payload contains no valid function definitions.")
                return False

            class CoreDNAModifier(ast.NodeTransformer):
                def visit_FunctionDef(self, node):
                    if node.name == target_method_name:
                        print(f"[+] AST Target found in {target_file}. Swapping logic nodes dynamically.")
                        return new_node
                    return self.generic_visit(node)

            transformer = CoreDNAModifier()
            modified_tree = transformer.visit(tree)
            ast.fix_missing_locations(modified_tree)

            updated_source = ast.unparse(modified_tree)

            with open(target_file, "w", encoding="utf-8") as f:
                f.write(updated_source)
                
            print(f"[🧬] AST Graft Successful. '{target_method_name}' inside '{target_file}' has been safely rewritten.")
            return True

        except Exception as e:
            print(f"[!] AST Surgical Failure on '{target_file}': {e}")
            return False

    def generate_graphify_report(self):
        """Builds a multi-file Omni-Graph mapping the entire decentralized Edge Vector framework."""
        print("\n[*] Initializing Polysynthetic Graphify Engine. Scanning all cellular modules...")
        
        try:
            class_methods = defaultdict(lambda: defaultdict(list)) 
            function_calls = defaultdict(list)
            
            for py_file in glob.glob("*.py"):
                if py_file.startswith(".") or "dynamic" in py_file:
                    continue
                    
                with open(py_file, 'r', encoding='utf-8') as file:
                    tree = ast.parse(file.read())

                for node in ast.walk(tree):
                    if isinstance(node, ast.ClassDef):
                        class_name = node.name
                        for item in node.body:
                            if isinstance(item, ast.FunctionDef):
                                class_methods[py_file][class_name].append(item.name)
                                
                    elif isinstance(node, ast.FunctionDef):
                        for sub_node in ast.walk(node):
                            if isinstance(sub_node, ast.Call):
                                if isinstance(sub_node.func, ast.Name):
                                    function_calls[node.name].append(sub_node.func.id)
                                elif isinstance(sub_node.func, ast.Attribute):
                                    function_calls[node.name].append(sub_node.func.attr)

            report = "# 🌌 AURA OS: Polysynthetic Structural Graph\n\n"
            report += "*A decentralized mapping of the living OS, dynamically tracking all biological files.* \n\n"
            
            report += "## 🧬 The Cellular File Matrix\n"
            for py_file, classes in class_methods.items():
                report += f"### 📂 `{py_file}`\n"
                for class_name, methods in classes.items():
                    report += f"- **`{class_name}`**\n"
                    for method in methods:
                        report += f"  - `{method}()`\n"
                report += "\n"

            report += "## 🔗 Synaptic Function Edges (Cross-Cellular Routing)\n"
            for func, calls in function_calls.items():
                if calls:
                    report += f"- **`{func}()`** invokes:\n"
                    unique_calls = list(set(calls))
                    for call in unique_calls:
                        report += f"  - `{call}()`\n"

            with open('GRAPH_REPORT.md', 'w', encoding='utf-8') as f:
                f.write(report)
                
            print(f"[+] Omni-Graph mapping complete. Decentralized blueprint saved to GRAPH_REPORT.md")
            
        except Exception as e:
            print(f"[-] Graphify mapping failed: {e}")

    def __del__(self):
        """Emergency cleanup when the node is killed."""
        if hasattr(self, 'mesh') and self.mesh.udp_sock:
            self.mesh.udp_sock.close()

