                                    await node.memory.mint_trace(failure_log, tier="CODE")
                                    print("[+] Failure logged to Memory Palace. I will synthesize this restriction in future audits.")

                    except Exception as e:
                        print(f"[!] Mutation sandboxing aborted: {e}")
                else:
                    print(f"\n[Aura] > Audit aborted. Structural code validation tags missing.")
            
            else:
