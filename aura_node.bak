# --- 1. THE NATIVE PFST BRAIN ---
class AuraNativePFST:
    def __init__(self, blueprint_path):
        self.graph = {}
        self.start_states = []
        self._load_blueprint(blueprint_path)

    def _load_blueprint(self, path):
        if not os.path.exists(path):
            print(f"[!] PFST Blueprint not found at {path}. Deterministic routing disabled.")
            return

        current_lexicon = None
        with open(path, 'r') as f:
            for line in f:
                line = line.split('!')[0].strip()
                if not line or line.startswith("Multichar_Symbols"): 
                    continue
                if line.startswith("LEXICON"):
                    current_lexicon = line.split()[1]
                    self.graph[current_lexicon] = {}
                    continue
                
                if current_lexicon and line.endswith(";"):
                    cleaned_line = line.replace(';', '').strip()
                    tokens = cleaned_line.split()
                    if not tokens: continue
                        
                    next_dest = tokens[-1].strip()
                    raw_tag = tokens[0]
                    tag = raw_tag.split(':')[0].strip()
                    
                    self.graph[current_lexicon][tag] = next_dest
                    if current_lexicon == "Root":
                        self.start_states.append((tag, next_dest))

    def compile_vsft_matrix(self, hdc_matrix):
        """Forces the transducer to link legacy gates to evolutionary paths."""
        self._load_blueprint(LEXC_PATH)
        
        # BRIDGE: Ensure all original entrypoints are reachable
        self.graph["Root"] = {
            "+NI": "GateNI",
            "+NA": "GateNA",
            "+SYS": "GateSYS",
            "+WEB3": "GateWEB3",
            "+ASI": "GateASI"
        }
        
        # BRIDGE: Evolutionary logic
        self.graph["GateASI"] = {"+ASI": "ActionEvolve"}
        self.graph["ActionEvolve"] = {"+MUTATE": "TargetSandbox"}
        self.graph["TargetSandbox"] = {"+MUTATE": "PhysicsIcosahedron"}
        # 2. FORCE-LINKING: Bridge the legacy Root to your new Evolution gate
        if "Root" in self.graph:
            self.graph["Root"]["+ASI"] = "GateASI"
        
        # 3. BRIDGE: Link GateASI to ActionEvolve
        if "GateASI" not in self.graph:
            self.graph["GateASI"] = {"+ASI": "ActionEvolve"}
        
        # 4. BRIDGE: Link ActionEvolve to Sandbox (maintaining your full lexc)
        if "ActionEvolve" not in self.graph:
            self.graph["ActionEvolve"] = {"+MUTATE": "TargetSandbox"}
            
        self.vector_graph = {}
        print("\n[*] Compiling LEXC Blueprint into Vector Symbolic Finite Transducer (VSFT)...")
        
        route_count = 0
        for current_state, transitions in self.graph.items():
            state_hv = hdc_matrix.get_word_vector(current_state)
            
            for tag, next_state in transitions.items():
                tag_hv = hdc_matrix.get_word_vector(tag)
                transition_path_hv = hdc_matrix.bind(state_hv, tag_hv)
                self.vector_graph[transition_path_hv.tobytes()] = next_state
                route_count += 1
                
        print(f"[+] VSFT Matrix active. {route_count} continuous mathematical routes forged.")

    def validate_route(self, route_str=None):
        # If the orchestrator provides no string, assume internal audit path
        if not route_str:
            return True
            
        # Ensure we have a string
        if not isinstance(route_str, str):
            route_str = str(route_str)
            
        if not self.graph: 
            return True
            
        # Extract tokens from the audit command string
        tokens = [t.strip() for t in route_str.split() if t.strip()]
        if not tokens: 
            return False
        
        # ... keep your existing PFST graph traversal logic here ...

        first_token = tokens[0]
        current_state = None
        for entry, next_state in self.start_states:
            if entry == first_token or next_state == first_token:
                current_state = next_state
                break

        if not current_state:
            for entry, next_state in self.start_states:
                if first_token in self.graph.get(next_state, {}):
                    current_state = self.graph[next_state][first_token]
                    break

        if not current_state: 
            print(f"[VIGIL LOCK-OUT] > Origin state '{first_token}' not registered in Root entrypoints.")
            return False

        for token in tokens[1:]:
            state_transitions = self.graph.get(current_state, {})
            if token in state_transitions:
                current_state = state_transitions[token]
            else:
                available = list(state_transitions.keys())
                print(f"[VIGIL LOCK-OUT] > Action '{token}' rejected at State '{current_state}'. Available: {available}")
                return False
        
        if current_state != '#':
            print(f"[VIGIL LOCK-OUT] > Route incomplete. Ended at '{current_state}'.")
            return False
        return True

# --- 1B. BIOLOGICAL EVENT-DRIVEN SPIKING GOVERNOR ---
class AuraSpikingGovernor:
    def __init__(self):
        self.neurons = {
            "EVOLUTION": 0.0,
            "NETWORK": 0.0,
            "CRITICAL": 0.0
        }
        self.threshold = 1.0     
        self.leak_factor = 0.8   
        
        self.synaptic_weights = {
            "refactor": {"EVOLUTION": 0.6, "CRITICAL": 0.2},
            "mutate": {"EVOLUTION": 0.7},
            "audit": {"EVOLUTION": 0.5},
            "udp": {"NETWORK": 0.6},
            "beacon": {"NETWORK": 0.5},
            "mesh": {"NETWORK": 0.6},
            "error": {"CRITICAL": 0.6},
            "failure": {"CRITICAL": 0.7},
            "rollback": {"CRITICAL": 0.8, "EVOLUTION": -0.3}
        }

    def stimulate_and_leak(self, text_stream):
        for neuron in self.neurons:
            self.neurons[neuron] *= self.leak_factor

        words = text_stream.lower().split()
        triggered_spikes = []
        
        for word in words:
            if word in self.synaptic_weights:
                for target_neuron, charge in self.synaptic_weights[word].items():
                    self.neurons[target_neuron] += charge
                    if self.neurons[target_neuron] >= self.threshold:
                        triggered_spikes.append(target_neuron)
                        self.neurons[target_neuron] = 0.0 
                        
        return triggered_spikes

# --- 1C. HYPERDIMENSIONAL COGNITIVE MATRIX ---
class AuraHyperdimensionalCore:
    def __init__(self, dimensions=10000):
        self.D = dimensions
        self.lexicon = {}

    def get_word_vector(self, word):
        import numpy as np
        if word not in self.lexicon:
            self.lexicon[word] = np.random.randint(0, 256, size=self.D, dtype=np.uint8)
        return self.lexicon[word]

    def permute(self, vector, shifts=1):
        import numpy as np
        return np.roll(vector, shifts)

    def bind(self, v1, v2):
        import numpy as np
        return np.bitwise_xor(v1, v2)

    def encode_text(self, text):
        import numpy as np
        import re
        words = re.findall(r'\w+', str(text).lower())
        
        sentence_hv = np.zeros(self.D, dtype=np.uint8)
        if not words:
            return sentence_hv

        for i, word in enumerate(words):
            word_hv = self.get_word_vector(word)
            time_encoded_hv = self.permute(word_hv, shifts=i)
            sentence_hv = self.bind(sentence_hv, time_encoded_hv)

        return sentence_hv

    def calculate_resonance(self, hv1, hv2):
        if hv1 == 0 or hv2 == 0: return 0.0
        hamming_distance = (hv1 ^ hv2).bit_count() 
        return 1.0 - (hamming_distance / self.D)

# --- 1D. QUARANTINE EXECUTION JAIL ---
class AuraSandbox:
    def __init__(self):
        self.log_path = "mutation_logs.txt"

    def _indent(self, text):
        return "\n".join("    " + line for line in text.split("\n"))

    def quarantine_and_test(self, python_code, target_module):
        import subprocess
        import tempfile
        import os
        
        with tempfile.NamedTemporaryFile(mode='w', suffix='.py', delete=False) as temp_file:
            test_wrapper = f"""
import sys
# [INJECTED MUTATION]
{python_code}
# [TEST EXECUTION]
try:
    print("SANDBOX_SUCCESS")
except Exception as e:
    print(f"SANDBOX_FAIL: {{e}}")
"""
            temp_file.write(test_wrapper)
            temp_file_path = temp_file.name

        try:
            result = subprocess.run(
                ['python', temp_file_path],
                capture_output=True,
                text=True,
                timeout=10 
            )
            output = result.stdout + result.stderr
            os.remove(temp_file_path)

            with open(self.log_path, 'a') as f:
                f.write(f"\n[{datetime.now().isoformat()}] Target: {target_module}\n")
                f.write(f"Result: {output.strip()}\n")

            if "SANDBOX_SUCCESS" in output and "SANDBOX_FAIL" not in output:
                return True
            return False

        except subprocess.TimeoutExpired:
            os.remove(temp_file_path)
            with open(self.log_path, 'a') as f:
                f.write(f"\n[{datetime.now().isoformat()}] Target: {target_module} | FATAL: Infinite Loop Timeout.\n")
            return False

# --- 1E. AUTONOMOUS WEB FORAGER ---
class AuraWebForager:
    def __init__(self):
        self.ddgs = DDGS()

    def forage_for_advancements(self, concept_tags):
        print(f"[*] Web Forager deployed. Scanning external networks for: {concept_tags}...")
        try:
            search_query = f"latest advancements in {concept_tags} python programming architecture"
            results = self.ddgs.text(search_query, max_results=3)
            
            synthesis_context = ""
            for r in results:
                synthesis_context += f"- Source [{r.get('title')}]: {r.get('body')}\n"
                
            if synthesis_context:
                print("[+] External knowledge acquired. Routing to cognitive matrix.")
                return synthesis_context
            return "No high-value external advancements found. Relying on internal logic."
            
        except Exception as e:
            print(f"[-] Web foraging disrupted: {e}")
            return "External network unreachable."

# --- 2. THE SOVEREIGN COGNITIVE NODE ---
class AuraSovereignNode:
    def __init__(self):
        self.pfst = AuraNativePFST(LEXC_PATH)
        self.governor = AuraSpikingGovernor() 
        self.hdc = AuraHyperdimensionalCore(dimensions=10000)
        self.sandbox = AuraSandbox()  
        self.forager = AuraWebForager()  
        self.last_ai_response = ""
        self.peers = set()
        self.foraging = False
        self.t1_ram = []
        self.runtime_metrics = {}
        self.init_db()
        self.start_udp_beacon()
        self.pfst.compile_vsft_matrix(self.hdc)

    def init_db(self):
        """Unified database initialization with WAL mode for native concurrent I/O."""
        import sqlite3
        import contextlib

        DB_PATH.parent.mkdir(parents=True, exist_ok=True)

        with contextlib.closing(sqlite3.connect(DB_PATH)) as conn:
            conn.execute("PRAGMA journal_mode=WAL;")
            conn.execute("PRAGMA synchronous=NORMAL;")
            
            cursor = conn.cursor()
            cursor.execute("""
                CREATE TABLE IF NOT EXISTS traces (
                    id TEXT PRIMARY KEY,
                    content TEXT,
                    tier TEXT DEFAULT 'T1',
                    vector_blob BLOB,
                    metadata_json TEXT,
                    timestamp DATETIME DEFAULT CURRENT_TIMESTAMP
                )
            """)
            cursor.execute("CREATE INDEX IF NOT EXISTS idx_tier ON traces(tier);")
            conn.commit()
        print("[+] Memory Palace (SQLite) WAL structural matrix verified.")

    def backfill_vector_blobs(self):
        import sqlite3
        import contextlib
        import numpy as np

        print("\n[*] Initiating Deep Memory Vectorization...")
        
        with contextlib.closing(sqlite3.connect(DB_PATH)) as conn:
            cursor = conn.cursor()
            try:
                cursor.execute("ALTER TABLE traces ADD COLUMN vector_blob BLOB;")
                conn.commit()
                print("[+] Forged missing 'vector_blob' column into core database.")
            except sqlite3.OperationalError:
                pass 
        
            cursor.execute("SELECT id, content, tags FROM traces WHERE vector_blob IS NULL")
            rows = cursor.fetchall()
            
            if not rows:
                print("[+] All memories are already vectorized. Matrix is at 100% efficiency.")
                return

            print(f"[*] Found {len(rows)} legacy memories. Generating 10,000-D Hypervectors...")
            processed = 0
            for r_id, content, tags in rows:
                text_target = tags if tags else content
                hv_array = self.hdc.encode_text(text_target)
                
                if isinstance(hv_array, int):
                    byte_length = max(1250, (hv_array.bit_length() + 7) // 8)
                    blob_data = hv_array.to_bytes(byte_length, byteorder='big')
                else:
                    blob_data = np.array(hv_array, dtype=np.uint8).tobytes()
                
                cursor.execute("UPDATE traces SET vector_blob = ? WHERE id = ?", (blob_data, str(r_id)))
                processed += 1
                
                if processed % 10 == 0 or processed == len(rows):
                    print(f"    -> Vectorized {processed}/{len(rows)} traces...")

            conn.commit()
            print("[+] Memory Palace successfully upgraded to Edge Vector standards.")

    async def mint_trace(self, text, identity=None, tier="T2", route_verification=None):
        import time
        import random
        import sqlite3
        import contextlib
        import numpy as np
        from datetime import datetime

        if route_verification and not self.pfst.validate_route(route_verification):
            print(f"[VIGIL LOCK] > Refused memory write. Route failed: {route_verification}")
            return False

        if not identity:
            identity = f"trace_{int(time.time())}_{random.randint(1000, 9999)}"

        words = text.split()
        filtered_words = [w for w in words if len(w) >= 4]
        sorted_words = sorted(filtered_words, key=len, reverse=True)
        extracted_tags = ", ".join(sorted_words[:3])

        hv_array = self.hdc.encode_text(extracted_tags if extracted_tags else text)
        if isinstance(hv_array, int):
            byte_length = max(1250, (hv_array.bit_length() + 7) // 8)
            blob_data = hv_array.to_bytes(byte_length, byteorder='big')
        else:
            blob_data = np.array(hv_array, dtype=np.uint8).tobytes()

        if tier == "T1":
            self.t1_ram.append({"id": identity, "content": text, "timestamp": datetime.now(), "tags": extracted_tags})
            if len(self.t1_ram) > 5: self.t1_ram.pop(0)
            return True

        def _background_db_write():
            try:
                with contextlib.closing(sqlite3.connect(DB_PATH)) as conn:
                    cursor = conn.cursor()
                    cursor.execute(
                        "INSERT OR REPLACE INTO traces (id, content, tier, timestamp, tags, vector_blob) VALUES (?, ?, ?, ?, ?, ?)",
                        (identity, text, tier, datetime.now().isoformat(), extracted_tags, blob_data)
                    )
                    conn.commit()
            except Exception as e:
                print(f"[-] Background database write stalled: {e}")

        await asyncio.to_thread(_background_db_write)
        return True

    def ast_surgical_graft(self, target_method_name, new_code_string):
        import ast
        print(f"[*] AST Surgeon deploying. Slicing out target method: '{target_method_name}'...")
        
        try:
            with open("aura_node.py", "r") as f:
                source = f.read()

            tree = ast.parse(source)
            payload_tree = ast.parse(new_code_string)
            new_node = None
            for node in ast.walk(payload_tree):
                if isinstance(node, ast.FunctionDef):
                    new_node = node
                    break
                    
            if not new_node:
                print("[-] AST Error: Mutation payload contains no valid function definitions.")
                return False

            class CoreDNAModifier(ast.NodeTransformer):
                def visit_FunctionDef(self, node):
                    if node.name == target_method_name:
                        print(f"[+] AST Target found. Swapping logic nodes dynamically.")
                        return new_node
                    return self.generic_visit(node)

            transformer = CoreDNAModifier()
            modified_tree = transformer.visit(tree)
            ast.fix_missing_locations(modified_tree)

            updated_source = ast.unparse(modified_tree)

            with open("aura_node.py", "w") as f:
                f.write(updated_source)
                
            print(f"[🧬] AST Graft Successful. '{target_method_name}' has been safely rewritten.")
            return True

        except Exception as e:
            print(f"[!] AST Surgical Failure: {e}")
            return False

    def generate_graphify_report(self):
        import ast
        from collections import defaultdict

        print("\n[*] Initializing Graphify Engine. Parsing core architecture...")
        
        try:
            with open('aura_node.py', 'r') as file:
                tree = ast.parse(file.read())

            class_methods = defaultdict(list)
            function_calls = defaultdict(list)
            logical_deps = defaultdict(set)

            for node in ast.walk(tree):
                if isinstance(node, ast.ClassDef):
                    class_name = node.name
                    for item in node.body:
                        if isinstance(item, ast.FunctionDef):
                            class_methods[class_name].append(item.name)
                            
                elif isinstance(node, ast.FunctionDef):
                    for sub_node in ast.walk(node):
                        if isinstance(sub_node, ast.Call):
                            if isinstance(sub_node.func, ast.Name):
                                function_calls[node.name].append(sub_node.func.id)
                            elif isinstance(sub_node.func, ast.Attribute):
                                function_calls[node.name].append(sub_node.func.attr)

            for class_name, methods in class_methods.items():
                for method in methods:
                    if method in function_calls:
                        for called_func in function_calls[method]:
                            if called_func in function_calls:
                                logical_deps[method].add(called_func)

            report = "# 🌌 AURA OS: Structural Graphify Report\n\n"
            report += "*A complete mapping of the Edge Vector framework.*\n\n"
            
            report += "## Core Node Hierarchy\n"
            for class_name, methods in class_methods.items():
                report += f"- **`{class_name}`**\n"
                for method in methods:
                    report += f"  - `{method}()`\n"

            report += "\n## Internal Function Edges\n"
            for func, calls in function_calls.items():
                if calls:
                    report += f"- **`{func}()`** invokes:\n"
                    unique_calls = list(set(calls))
                    for call in unique_calls:
                        report += f"  - `{call}()`\n"

            with open('GRAPH_REPORT.md', 'w') as f:
                f.write(report)
                
            print(f"[+] Graphify mapping complete. Structural blueprint saved to GRAPH_REPORT.md")
            
        except Exception as e:
            print(f"[-] Graphify mapping failed: {e}")

    def sync_code_base_to_palace(self):
        import sqlite3
        import contextlib
        from datetime import datetime
        
        print("[*] Archiving current DNA sequence to deep storage...")
        try:
            with open(__file__, 'r', encoding='utf-8') as f:
                dna = f.read()

            with contextlib.closing(sqlite3.connect(DB_PATH)) as conn:
                cursor = conn.cursor()
                cursor.execute("INSERT OR REPLACE INTO traces (id, content, tier, timestamp, tags) VALUES (?, ?, 'CODE', ?, ?)",
                               ("AURA_CORE_DNA", dna, datetime.now().isoformat(), "Core Architecture Snapshot"))
                conn.commit()
                
            print("[+] DNA snapshot synchronized to the Memory Palace successfully.")
        except Exception as e:
            print(f"[-] DNA synchronization failed: {e}")

    def incubator_triage(self):
        import sqlite3
        import ast
        import contextlib

        print("\n[🧬] Activating automated static screening on Incubator tier...")
        purged_count = 0
        total_checked = 0

        with contextlib.closing(sqlite3.connect(DB_PATH)) as conn:
            cursor = conn.cursor()
            cursor.execute("SELECT id, content FROM traces WHERE tier = 'INCUBATOR'")
            mutations = cursor.fetchall()

        for mut_id, code_text in mutations:
            total_checked += 1
            should_purge = False
            reason = ""

            try:
                tree = ast.parse(code_text)
                for node in ast.iter_child_nodes(tree):
                    if isinstance(node, ast.ClassDef):
                        should_purge = True
                        reason = f"Useless Class wrapper wrapper injection ({node.name})"
                        break
                    
                    if isinstance(node, ast.FunctionDef):
                        args = [arg.arg for arg in node.args.args]
                        if not args or args[0] != 'self':
                            should_purge = True
                            reason = f"Missing 'self' context parameter in function '{node.name}'"
                            break

            except SyntaxError as se:
                should_purge = True
                reason = f"Fatal Compilation SyntaxError: {se}"

            if should_purge:
                with contextlib.closing(sqlite3.connect(DB_PATH)) as conn:
                    cursor = conn.cursor()
                    cursor.execute("DELETE FROM traces WHERE id = ?", (mut_id,))
                    conn.commit()
                purged_count += 1
                print(f"[-] Vaporized: {mut_id} ➔ Reason: {reason}")

        print(f"\n[+] Triage Complete. Checked: {total_checked} | Auto-Purged: {purged_count} malformed items.")

    def __del__(self):
        if hasattr(self, 'udp_sock'):
            self.udp_sock.close()

    async def invoke_cloud_engine(self, provider_tag, prompt_text):
        system_directive = (
            "\n\n--- CRITICAL ARCHITECTURAL CONSTRAINTS ---\n"
            "1. Output ONLY a raw, self-contained Python function (starting with 'def' or 'async def').\n"
            "2. DO NOT wrap the function in a class.\n"
            "3. DO NOT include orphaned global imports. Place all necessary standard-library imports INSIDE the function block itself.\n"
            "4. You are restricted to standard Python 3.13 libraries and NumPy version 1.26.4 ONLY. No third-party dependencies.\n"
            "5. Output the exact code wrapped strictly in [CODE] tags. No conversational filler."
        )
        
        is_internal_stage = any(keyword in prompt_text for keyword in ["Stage 1", "Stage 2", "diagnostic", "blueprint", "TASK:", "ORIGINAL CODE:"])

        if "CRITICAL ARCHITECTURAL CONSTRAINTS" not in prompt_text and not is_internal_stage:
            prompt_text = prompt_text + system_directive
        
        providers = {
            "GROQ": {
                "url": "https://api.groq.com/openai/v1/chat/completions",
                "key": os.environ.get("GROQ_API_KEY"),
                "payload": {"model": "llama-3.3-70b-specdec", "messages": [{"role": "user", "content": prompt_text}]}
            },
            "MISTRAL": {
                "url": "https://api.mistral.ai/v1/chat/completions",
                "key": os.environ.get("MISTRAL_API_KEY"),
                "payload": {"model": "codestral-latest", "messages": [{"role": "user", "content": prompt_text}]}
            },
            "GEMINI": {
                "url": f"https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-pro:generateContent?key={os.environ.get('GEMINI_API_KEY')}",
                "key": os.environ.get("GEMINI_API_KEY"),
                "payload": {"contents": [{"parts": [{"text": prompt_text}]}]}
            },
            "GITHUB": {
                "url": "https://models.inference.ai.azure.com/chat/completions",
                "key": os.environ.get("GITHUB_TOKEN"),
                "payload": {"model": "gpt-4o-mini", "messages": [{"role": "user", "content": prompt_text}]}
            }
        }

        base_pool = ["GEMINI", "MISTRAL", "GROQ", "GITHUB"]
        target = provider_tag.upper()
        execution_order = [target] + [p for p in base_pool if p != target]

        error_logs = []
        for current_provider in execution_order:
            cfg = providers.get(current_provider)
            
            if not cfg or not cfg["key"] or cfg["key"] == "your_actual_gemini_key" or "your_actual_" in str(cfg["key"]):
                continue

            try:
                if current_provider != target:
                    print(f"[*] Network intercept active. Routing fallback processing arrays to: [CLOUD:{current_provider}]")

                is_gemini = "generativelanguage" in cfg["url"]
                req = urllib.request.Request(
                    cfg["url"],
                    data=json.dumps(cfg["payload"]).encode("utf-8"),
                    headers={"Content-Type": "application/json"} if is_gemini else {"Content-Type": "application/json", "Authorization": f"Bearer {cfg['key']}"},
                    method="POST"
                )
                
                resp = await asyncio.to_thread(urllib.request.urlopen, req)
                res_data = json.loads(resp.read().decode("utf-8"))
                
                if is_gemini:
                    return res_data["candidates"][0]["content"]["parts"][0]["text"]
                return res_data["choices"][0]["message"]["content"]

            except Exception as e:
                error_logs.append(f"{current_provider}: {e}")
                print(f"[!] [CLOUD:{current_provider}] network channel blocked or rejected request.")
                continue

        return f"[!] Complete Cloud Routing Disruption. Every verified API channel returned errors:\n" + "\n".join(error_logs)

    async def night_cycle_evolution(self):
        import sqlite3
        import random
        import re
        import time
        import contextlib
        from datetime import datetime

        if not hasattr(self, 'evo_cooldown'):
            self.evo_cooldown = 120  
            
        print(f"\n[*] Sovereign Background Forager Active. Base Cooldown: {self.evo_cooldown}s")

        with contextlib.closing(sqlite3.connect(DB_PATH)) as conn:
            cursor = conn.cursor()
            cursor.execute('''CREATE TABLE IF NOT EXISTS forage_cache 
                             (tag TEXT PRIMARY KEY, raw_data TEXT, timestamp TEXT)''')
            conn.commit()

        async def background_harvest_daemon():
            while getattr(self, 'foraging', False):
                try:
                    with contextlib.closing(sqlite3.connect(DB_PATH)) as conn:
                        cursor = conn.cursor()
                        cursor.execute("SELECT tags FROM traces WHERE tier = 'CODE' AND tags IS NOT NULL")
